---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchGraphQL } from '../../lib/api';
import '../../styles/post.css';
import GET_ALL_DJS from '../../lib/queries/getAllDJs';
import type { DJ, Post } from '../../types';

const fallbackImage = '/blog-placeholder-1.jpg';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let postsByDJ: Post[] = [];

try {
  type PageInfo = { hasNextPage?: boolean; endCursor?: string | null };

  // First: paginate through all DJ nodes to find the target DJ
  let djsAfter: string | undefined;
  let foundDJNode: DJ | null = null;

  while (!foundDJNode) {
    const response = await fetchGraphQL(GET_ALL_DJS, { postsFirst: 100, djsAfter });
    const djNodes: DJ[] = response?.dJs?.nodes || [];

    foundDJNode = djNodes.find((dj: DJ) => dj?.slug === slug) || null;

    const djsPageInfo: PageInfo = response?.dJs?.pageInfo || {};
    if (!foundDJNode && djsPageInfo.hasNextPage) {
      djsAfter = djsPageInfo.endCursor ?? undefined;
    } else {
      break;
    }
  }

  if (foundDJNode) {
    // Collect posts from the initial fetch
    const initialPosts = (foundDJNode as unknown as { posts?: { nodes?: Post[]; pageInfo?: PageInfo } })?.posts;
    if (initialPosts?.nodes) postsByDJ = postsByDJ.concat(initialPosts.nodes);

    // Then paginate through remaining posts for this DJ
    let postsAfter: string | undefined = initialPosts?.pageInfo?.hasNextPage
      ? (initialPosts.pageInfo.endCursor ?? undefined)
      : undefined;

    while (postsAfter) {
      const response = await fetchGraphQL(GET_ALL_DJS, { postsFirst: 100, postsAfter, djsAfter });
      const djNodes: DJ[] = response?.dJs?.nodes || [];
      const matching = djNodes.find((dj: DJ) => dj?.slug === slug);
      const posts = (matching as unknown as { posts?: { nodes?: Post[]; pageInfo?: PageInfo } })?.posts;
      if (posts?.nodes) postsByDJ = postsByDJ.concat(posts.nodes);
      postsAfter = posts?.pageInfo?.hasNextPage ? (posts.pageInfo.endCursor ?? undefined) : undefined;
    }
  }
} catch (err) {
  console.error('Error fetching posts by DJ', err);
}

// biome-ignore lint/correctness/noUnusedVariables: Used in template
const capitaliseAndRemoveHyphens = (string: string | undefined) => {
  if (!string) return 'Unknown DJ';
  return string
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};
---

<BaseLayout
  pageTitle={capitaliseAndRemoveHyphens(slug)}
  description={`All posts of DJ ${capitaliseAndRemoveHyphens(slug)}`}
  opengraphImage={postsByDJ[0]?.seo?.opengraphImage?.sourceUrl || fallbackImage}
>
  <h1>DJ: {capitaliseAndRemoveHyphens(slug)}</h1>

  {
    postsByDJ.length === 0 ? (
      <section>
        <p>
          No posts found for <strong>{capitaliseAndRemoveHyphens(slug)}</strong>.
        </p>
        <p>
          You can <a href="/">return to the homepage</a> or try a different DJ.
        </p>
      </section>
    ) : (
      <ul>
        {postsByDJ.map((post, index) => (
          <li class="genres-list">
            <div class="image-container">
              <a href={`/${post?.slug}`}>
                <img
                  src={post?.featuredImage?.node?.sourceUrl || fallbackImage}
                  srcset={post?.featuredImage?.node?.srcSet}
                  alt=""
                  sizes="(max-width: 600px) 100vw, 700px"
                  width={700}
                  height={466.67}
                  class="featured-image"
                  loading={index < 2 ? 'eager' : 'lazy'}
                />
                {post?.featuredImage?.node?.caption && (
                  <figcaption set:html={post.featuredImage.node.caption} />
                )}
              </a>
            </div>
            <h2>
              <a href={`/${post?.slug}`}>{post?.title}</a>
            </h2>
            <ul class="genres">
              <li>
                {post?.genres.nodes.map((genre, index) => (
                  <span>
                    <a href={`/genre/${genre.slug}`} rel="noopener noreferrer">
                      {genre.name}
                    </a>
                    {index < post.genres.nodes.length - 1 && ', '}
                  </span>
                ))}
              </li>
            </ul>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
