---
/** biome-ignore-all lint/correctness/noUnusedVariables: <explanation> */
/** biome-ignore-all lint/correctness/noUnusedImports: <explanation> */

import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchGraphQL } from '../lib/api';

import '../styles/pages.css';
import GET_DJ_NAMES from '../lib/queries/getDJNames';
import type { DJ, DJs } from '../types';

let djNodes: DJ[] = [];

try {
  let after: string | undefined;
  while (true) {
    const response: DJs = await fetchGraphQL(GET_DJ_NAMES, { after });
    const page = response?.dJs;
    if (page?.nodes) djNodes = djNodes.concat(page.nodes);
    if (page?.pageInfo?.hasNextPage) {
      after = page.pageInfo.endCursor ?? undefined;
    } else {
      break;
    }
  }
} catch (error) {
  console.error('Error fetching all DJs:', error);
}

const sortedDJs = djNodes
  .filter((dj) => dj && dj.count > 0)
  .sort((a, b) => (a?.name ?? '').localeCompare(b?.name ?? ''));
---

<BaseLayout pageTitle="DJs">
  <article>
    <h1>DJs</h1>
    <p>
      Explore all DJs featured on the site. Click on a DJ to view all their mixes.
    </p>
    <ul class="genre-list">
      {
        sortedDJs?.map((dj) => (
          <li>
            <h2>
              <a href={`dj/${dj?.slug}`} rel="noopener noreferrer">
                <Fragment set:html={dj?.name} />
              </a>
            </h2>
          </li>
        ))
      }
    </ul>
  </article>
</BaseLayout>
