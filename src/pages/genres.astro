---
/** biome-ignore-all lint/correctness/noUnusedVariables: <explanation> */
/** biome-ignore-all lint/correctness/noUnusedImports: <explanation> */

import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchGraphQL } from '../lib/api';

import '../styles/pages.css';
import GET_GENRE_NAMES from '../lib/queries/getGenreNames';
import type { Genres } from '../types';

let allGenres: Genres = null;

try {
  allGenres = await fetchGraphQL(GET_GENRE_NAMES);
} catch (error) {
  console.error('Error fetching all genres:', error);
}

const genresJson = JSON.stringify(allGenres?.genres.nodes ?? []);
---

<BaseLayout pageTitle="Home">
  <article>
    <h1>Genres</h1>
    <p>
      Explore the genres of DJ mixes available on the site. Click on a genre to view all mixes in
      that genre
    </p>
    <div
      x-data={`{ genres: ${genresJson}, sort: 'count', get sortedGenres() { return [...this.genres].sort((a, b) => this.sort === 'count' ? (b.count ?? 0) - (a.count ?? 0) : a.name.localeCompare(b.name)); } }`}
    >
      <div class="sort-controls">
        <button @click="sort = 'count'" :class="{ active: sort === 'count' }">Most Mixes</button>
        <button @click="sort = 'name'" :class="{ active: sort === 'name' }">A–Z</button>
      </div>
      <ul class="genre-list">
        <template x-for="genre in sortedGenres" :key="genre.id">
          <li>
            <h2>
              <a :href="`genre/${genre.slug}`" rel="noopener noreferrer" x-html="genre.name"></a>
            </h2>
            <span class="genre-count" x-text="`${genre.count ?? 0} mix${(genre.count ?? 0) !== 1 ? 'es' : ''}`"></span>
          </li>
        </template>
      </ul>
    </div>
  </article>
</BaseLayout>
